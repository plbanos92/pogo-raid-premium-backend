# ------------------------------------------------------------------
# Copy this file to .env.local (dev), .env.staging, or .env.production
# and fill in the values for each environment.
# NEVER commit real .env files to source control.
# ------------------------------------------------------------------

# ---- Supabase project settings (required) ----

# Your Supabase project API URL.
# Dev example:     https://<dev-ref>.supabase.co
# Staging example: https://<staging-ref>.supabase.co
# Production:      https://jkzbruimweyolcgjmram.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co

# Public anon key — safe to use in client-side code.
# Find this in: Supabase Dashboard → Project Settings → API → Project API Keys
SUPABASE_ANON_KEY=<anon-key>

# Service role key — NEVER expose in frontend or commit to repo.
# Only use in server-side / admin scripts.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ---- Environment tag (optional, used for logging/monitoring) ----
APP_ENV=development
